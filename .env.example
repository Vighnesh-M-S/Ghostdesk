# ─── Required ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Gemini model to use (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# FastAPI backend URL (used by Streamlit frontend)
GHOSTDESK_API_URL=http://localhost:8000

# LangSmith observability (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=ghostdesk

# Database path (default: ./ghostdesk.db)
GHOSTDESK_DB_PATH=ghostdesk.db
